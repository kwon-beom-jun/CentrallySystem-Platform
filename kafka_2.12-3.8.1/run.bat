@echo off
REM =====================================================
REM Zookeeper 서버 실행 (새 창에서 실행)
REM =====================================================
start "Zookeeper Server" cmd /c "bin\windows\zookeeper-server-start.bat config\zookeeper.properties"

REM ------------------------------------------------------------------------------
REM timeout 명령어 설명:
REM ------------------------------------------------------------------------------
REM 1. timeout 명령어는 Windows 명령 프롬프트에서 내장되어 있는 명령어입니다.
REM    지정한 시간(초) 동안 대기하도록 하는 역할을 합니다.
REM
REM 2. /t 옵션:
REM    "/t 30" 은 30초 동안 대기하라는 의미입니다.
REM    즉, 이 명령어가 실행되면 30초 후에 다음 명령어로 넘어갑니다.
REM
REM 3. /nobreak 옵션:
REM    이 옵션은 사용자가 아무 키나 눌러도 대기 시간을 중단하지 않도록 합니다.
REM    기본적으로는 키 입력 시 대기 중단이 가능하지만, /nobreak을 사용하면 무시됩니다.
REM
REM 요약:
REM    "timeout /t 30 /nobreak" 명령어는 30초 동안 대기하며, 
REM    사용자가 키를 눌러도 대기 시간이 중단되지 않게 만들어 줍니다.
REM ------------------------------------------------------------------------------
REM 30초 대기
timeout /t 30 /nobreak

REM =====================================================
REM Kafka 서버 실행 (새 창에서 실행)
REM =====================================================
start "Kafka Server" cmd /c "bin\windows\kafka-server-start.bat config\server.properties"
